# Copy to .env for local dev. Defaults assume `make forward` is running so
# ClickHouse HTTP is reachable via the host-gateway alias.

# ClickHouse (curated schema). Password is empty for the default local user.
CLICKHOUSE_ENDPOINT_URL=warehouse-clickhouse-headless
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_PASSWORD=

# Cube API secret (JWT signing) - any string for local dev.
CUBEJS_API_SECRET=dev-secret

# SQL API credentials (the agent / psql connects with these).
CUBEJS_SQL_USER=cube
CUBEJS_SQL_PASSWORD=cube
