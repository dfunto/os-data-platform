{
  "name": "weather-hudi-sink",
  "config": {
    "connector.class": "org.apache.hudi.connect.HoodieSinkConnector",
    "tasks.max": "1",
    "topics": "weather",
    "hoodie.table.name": "weather",
    "hoodie.base.path": "s3a://REPLACE_BUCKET/hudi/weather",
    "hoodie.datasource.write.recordkey.field": "location",
    "hoodie.datasource.write.partitionpath.field": "",
    "hoodie.datasource.write.table.type": "COPY_ON_WRITE",
    "hoodie.datasource.write.operation": "upsert",
    "hoodie.kafka.commit.interval.secs": "60",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "fs.s3a.access.key": "${env:AWS_ACCESS_KEY_ID}",
    "fs.s3a.secret.key": "${env:AWS_SECRET_ACCESS_KEY}",
    "fs.s3a.endpoint": "s3.amazonaws.com",
    "fs.s3a.impl": "org.apache.hadoop.fs.s3a.S3AFileSystem"
  }
}